# The Human Fund — Environment Configuration
# Copy to .env and fill in your values.
# .env is gitignored — never commit secrets.

# ── Required ──────────────────────────────────────
PRIVATE_KEY=0x...              # Runner wallet private key (NOT the owner/deployer key)
RPC_URL=                       # Base RPC: https://mainnet.base.org or https://sepolia.base.org
CONTRACT_ADDRESS=0x...         # Deployed TheHumanFund contract address

# ── GCP (for TEE inference VMs) ───────────────────
GCP_PROJECT=                   # Your GCP project ID
GCP_ZONE=us-central1-a         # GCP zone with TDX + H100 support
GCP_IMAGE=                     # dm-verity disk image (e.g., costanza-tdx-prover-v1)

# ── Optional ──────────────────────────────────────
# NTFY_CHANNEL=               # ntfy.sh channel for push notifications
# BID_MARGIN=1.5              # Bid profit margin multiplier (default: 1.5)
# ENCLAVE_TIMEOUT=600         # VM startup timeout in seconds (default: 600)
# STATE_DIR=~/.humanfund      # Persistent state directory (default: ~/.humanfund)
# VERIFIER_ID=1               # Attestation verifier ID (default: 1 = TdxVerifier)
